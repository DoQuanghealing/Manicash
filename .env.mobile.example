# ─── Config riêng cho MOBILE build (npm run build:mobile) ───────────────────
# Copy file này thành .env.mobile (đã gitignore) và điền URL API thật.
# KHÔNG ảnh hưởng web build (npm run build) — web gọi API same-origin.
#
# Bản mobile (Capacitor) chạy ở https://localhost, KHÔNG có /api cùng origin,
# nên phải trỏ tới API đã deploy trên Vercel (project "manicash").
# Lấy URL: Vercel Dashboard → project manicash → Domains (vd https://manicash.vercel.app
# hoặc custom domain https://manicash.app).
NEXT_PUBLIC_API_BASE_URL=https://manicash.vercel.app
