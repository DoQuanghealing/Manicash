# ═══ ManiCash Environment Variables ═══

# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Firebase Admin SDK (server-side only; required for SMS Webhook API routes)
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# AI CFO (Groq — Llama 70B)
GROQ_API_KEY=your_groq_api_key_here

# ═══ Phase 1+ Feature Flags — 3-Account Model Migration ═══
# Reference: docs/adr/0001-three-account-model.md
# Default: all OFF (commented out). Only exact value "true" enables.
#
# Phase 1 gate — bật read model + migration planner (UI vẫn cũ)
# NEXT_PUBLIC_ENABLE_THREE_ACCOUNT_MODEL=true
#
# Phase 2 gate — bật Overview UI mới (4 chỉ số). Yêu cầu Phase 1 ON.
# NEXT_PUBLIC_ENABLE_NEW_OVERVIEW=true
#
# Phase 3 gate — bật allocation modal. Yêu cầu Phase 1 ON.
# NEXT_PUBLIC_ENABLE_ALLOCATION_FLOW=true
