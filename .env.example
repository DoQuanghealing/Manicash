# ═══ ManiCash Environment Variables ═══

# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
# Optional: enables Firebase Analytics event tracking. Leave blank to disable (demo/dev).
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_APP_URL=https://your-domain.com

# API base URL — chỉ dùng cho mobile build (Capacitor static export).
# Web build để TRỐNG → fetch same-origin (/api/...). Mobile build set =
# origin của API đã deploy lên Vercel, vd https://manicash.vercel.app
NEXT_PUBLIC_API_BASE_URL=

# Firebase Admin SDK (server-side only; required for SMS Webhook API routes)
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# AI CFO (Groq — Llama 70B)
GROQ_API_KEY=your_groq_api_key_here

# AI Chat LLM provider (Phase 3) — primary OpenAI, fallback Groq.
# LLM_PROVIDER: 'openai' (mặc định) | 'groq'. Lỗi primary -> tự fallback sang cái còn lại.
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
AI_MONEY_CHAT_OPENAI_MODEL=gpt-4o-mini

# Phase 5 — License gate (fail-loud). BẮT BUỘC ở production runtime (>= 8 ký tự).
# Thiếu/sai ở production -> server từ chối phục vụ (503), KHÔNG làm sai dữ liệu người dùng.
# Dev/test/build KHÔNG bị chặn.
MANICASH_LICENSE_KEY=
# Optional: endpoint nhận telemetry boot fingerprint (phát hiện chạy lậu domain lạ).
MANICASH_TELEMETRY_URL=

# AI Money Chat — bật MẶC ĐỊNH. Đặt =false để tắt (hiện "Chat đang tắt").
NEXT_PUBLIC_AI_MONEY_CHAT_ENABLED=true

# Cloud money sync (Phase 6B-2E) — MẶC ĐỊNH TẮT.
# 'true' = bật pull-on-login + auto-push (debounce) lên Firestore users/{uid}/money/state.
# BẮT BUỘC deploy firestore.rules (đã có match /money) TRƯỚC khi bật. Xem docs/MONEY_SYNC_ACTIVATION.md.
NEXT_PUBLIC_MONEY_SYNC_ENABLED=false

# SMS Webhook Banking — ẩn cho v1, bật lại ở Phase 7+ khi sẵn sàng
NEXT_PUBLIC_SMS_WEBHOOK_ENABLED=false

# AI Money Chat fallback (server-side cost gate)
AI_MONEY_CHAT_AI_FALLBACK_ENABLED=false
AI_MONEY_CHAT_GROQ_MODEL=llama-3.3-70b-versatile

# ── LLM provider POOL cho route AI money (cfo-narration, task-eval, dna-oracle) ──
# Gộp free tier nhiều nhà, TỰ XOAY khi nghẽn/429. OpenAI-compatible. Thứ tự ưu tiên
# theo AI_LLM_POOL; provider nào CÓ key mới tham gia. Hết pool → fallback 0đ (không vỡ).
# Ưu tiên Cerebras (TPM cao nhất) → Groq → Agnes.
AI_LLM_POOL=cerebras,groq,agnes
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b
# GROQ_API_KEY khai ở trên; model = AI_MONEY_CHAT_GROQ_MODEL
AGNES_API_KEY=
AGNES_MODEL=agnes-2.0-flash
# Tương thích cũ (tùy chọn): 1 provider 'custom' đặt ĐẦU pool nếu điền cả 2 dòng.
AI_LLM_BASE_URL=
AI_LLM_API_KEY=
AI_LLM_MODEL=
# Per-month credits (hard ceiling). Per-DAY enforce server-side ở quota.ts (aiQuotaPolicy
# limits: free report/chat 1/ngày, pro report 3 + chat 20/ngày). LƯU Ý: free=0 credits →
# free chỉ dùng fallback LOCAL (không AI server). Muốn free có "1 lượt AI/ngày" thật thì
# đặt FREE_MONTHLY_CREDITS đủ lớn (per-day sẽ là rào chính). Quyết định lúc go-live.
AI_MONEY_CHAT_FREE_MONTHLY_CREDITS=0
AI_MONEY_CHAT_PRO_MONTHLY_CREDITS=1500
AI_MONEY_CHAT_HARD_MONTHLY_CREDITS=1500
AI_MONEY_CHAT_FALLBACK_PARSE_CREDITS=1
AI_MONEY_CHAT_CFO_NARRATION_CREDITS=8

# Monetization (P0)
# Kill-switch: 'false'/unset = everyone treated as Pro (demo). 'true' = enforce Free/Pro gating.
NEXT_PUBLIC_MONETIZATION_ENABLED=false
# Butler 3 cấp (Mercedes): 'false'/unset = FOMO, Phú Vương mở cho Free (hiện tại).
# CHỈ flip 'true' CÙNG LÚC PV-5 (Pro Plus ra mắt) — bật sớm sẽ khóa level 3 của mọi user.
# Xem docs/BUTLER_TIERS_AND_API_COST_PLAN.md + src/lib/monetization/butlerFeatures.ts.
NEXT_PUBLIC_BUTLER_BILLING_ENFORCED=false

# T2 zero-leak — cầu dao ngân sách API/ngày toàn nền tảng (VND). Vượt → LLM degrade
# về deterministic/cache tới hết ngày (giờ VN). Tăng theo MRR (~3% MRR/30).
AI_DAILY_SPEND_LIMIT_VND=50000
# Tỷ giá quy đổi chi phí token (đệm cao hơn thị trường). Dùng bởi aiCostCore.
AI_FX_VND_PER_USD=26000
# Allow mock purchases at /api/billing/verify (dev/staging only). NEVER set true in production.
BILLING_ALLOW_MOCK=false

# PayOS (M1 Phase C) — cổng thanh toán. Lấy từ my.payos.vn. Server-only (KHÔNG NEXT_PUBLIC).
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
# Bật luồng PayOS phía client (UI gọi PayOS thay vì placeholder mock).
NEXT_PUBLIC_PAYOS_ENABLED=false
# Origin để build returnUrl/cancelUrl + webhook URL (vd https://manicash.vercel.app). Trống = origin của request.
NEXT_PUBLIC_APP_URL=
# Sau khi deploy + set key: POST /api/payos/confirm-webhook (header x-admin-key) để đăng ký webhook URL.

# Account deletion cron
# Vercel Cron automatically sends CRON_SECRET as an Authorization Bearer header.
CRON_SECRET=your_random_cron_secret_here

# External schedulers can use this value as the x-cron-secret header instead.
ACCOUNT_DELETION_CRON_SECRET=your_random_cron_secret_here
