rules_version = '2';

// ═══ ManiCash Firestore Security Rules ═══
// Server code uses the Admin SDK (firebase-admin) which BYPASSES these rules.
// These rules therefore only constrain the CLIENT SDK. Admin-only collections
// are denied to the client entirely; entitlement/billing fields are write-locked
// so a user can never grant themselves Pro from the client.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Entitlement + billing fields the client must NEVER write. Only the Admin
    // SDK (via /api/billing/verify) may set these.
    function protectedKeys() {
      return ['tier', 'plan', 'isPremium', 'premiumExpiresAt', 'billingProvider', 'billingOrderIds'];
    }

    function noProtectedFieldChange() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(protectedKeys());
    }

    // A newly created profile must start on the free tier.
    function createsAsFree() {
      return request.resource.data.get('tier', 'free') == 'free'
        && request.resource.data.get('plan', 'free') == 'free'
        && request.resource.data.get('isPremium', false) == false
        && request.resource.data.get('premiumExpiresAt', null) == null;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && createsAsFree();
      allow update: if isOwner(uid) && noProtectedFieldChange();
      allow delete: if false; // Deletion handled server-side via Admin SDK.

      // Finance core (event-sourced ledger) — fully client-managed by the owner.
      match /finance_core/{docId} {
        allow read, write: if isOwner(uid);
      }

      // Money sync (Phase 6B-2E) — aggregate money state doc, owner-only.
      // Doc: users/{uid}/money/state = { version, updatedAt, envelope }.
      // Client SDK reads/writes only its own; Admin SDK bypasses rules.
      match /money/{docId} {
        allow read, write: if isOwner(uid);
      }

      // Pending transactions — created by the SMS webhook (Admin SDK).
      // The owner may read them and dismiss (delete) them, but not create/edit.
      match /pending_transactions/{docId} {
        allow read, delete: if isOwner(uid);
        allow create, update: if false;
      }

      // AI usage quota + CFO narration cache — Admin SDK only.
      match /ai_usage/{monthKey} {
        allow read, write: if false;
      }
      match /cfo_narration/{monthKey} {
        allow read, write: if false;
      }

      // PV-3 Financial DNA (persona + báo cáo Oracle, dữ liệu nhạy cảm) — Admin SDK
      // only. Deny TƯỜNG MINH: không dựa vào default-deny catch-all cuối file, để
      // nếu sau này ai thêm rule rộng `users/{uid}/{doc=**}` thì doc này VẪN khoá.
      match /financial_dna/{docId} {
        allow read, write: if false;
      }
    }

    // SMS webhook tokens — the owner may read their token (settings page shows it);
    // creation/rotation and the recent-message dedup log are Admin SDK only.
    match /webhook_tokens/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;

      match /recent_msgs/{hash} {
        allow read, write: if false;
      }
    }

    // Server-only collections (Admin SDK bypasses rules; client has no access).
    match /account_deletion_requests/{docId} {
      allow read, write: if false;
    }

    // Monetization ledgers — Admin SDK only.
    // trial_ledger/{sha256(email)} + device_ledger/{sha256(deviceId)}: chống lách
    // dùng thử (sống sót qua xóa account / reinstall). grant_events: append-only
    // lịch sử cấp Pro (nguồn-sự-thật đếm phân loại/doanh thu, không lấy từ scalar).
    match /trial_ledger/{emailHash} {
      allow read, write: if false;
    }
    match /device_ledger/{deviceHash} {
      allow read, write: if false;
    }
    match /grant_events/{eventId} {
      allow read, write: if false;
    }

    // PayOS — Admin SDK only. payment_intents map orderCode→{uid,amount,plan,status};
    // payments_index = bảng phẳng doanh thu; payos_webhook_events = raw để replay.
    match /payment_intents/{orderCode} {
      allow read, write: if false;
    }
    match /payments_index/{orderCode} {
      allow read, write: if false;
    }
    match /payos_webhook_events/{eventId} {
      allow read, write: if false;
    }

    // Phiên hội thoại CFO follow-up (B-03 durable) — Admin SDK only.
    // Cấu hình Firestore TTL policy trên field `expiresAt` để tự dọn phiên cũ.
    match /ai_conversations/{sessionId} {
      allow read, write: if false;
    }

    // T2 zero-leak — sổ ghi từng lượt LLM + tổng chi/ngày (Admin SDK only).
    match /ai_usage_log/{entryId} {
      allow read, write: if false;
    }
    match /ai_spend_daily/{dayKey} {
      allow read, write: if false;
    }

    // Default deny for anything not matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
